/* 整个页面的容器样式（在此通过 background-image 自由设置首页背景图） */
.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  height: 95vh;
  padding: 60rpx 40rpx ;
  box-sizing: border-box;
  background-color: #FFFAE4;
  background-repeat: no-repeat;
  background-size: cover;
  background-position: center;
  background-image: url(https://meetmeow.oss-cn-wuhan-lr.aliyuncs.com/source/home/home_bg_background.png);
}

/* 用户信息顶栏样式 */
.top-bar {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10rpx 0;
  box-sizing: border-box;
  border-radius: 32rpx;
}

.user-section {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 24rpx;
}
/*商城和消息*/
.index-tool {
  width: 120rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.tool-item {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.tool-icon {
  width: 60rpx;
  height: 60rpx;
}


.user-section__avatar {
  width: 135rpx;
  height: 135rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(255, 217, 1, 0.9);
  box-shadow: 0 10rpx 24rpx rgba(0, 0, 0, 0.08);
}

.user-section__text {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.user-section__name-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.user-section__name {
  font-size: 36rpx;
  color: #1f1f1f;
  font-weight: 700;
}

.user-section__level {
  padding: 6rpx 16rpx;
  font-size: 24rpx;
  color: #999999;
  border-radius: 999rpx;
  border: 2rpx solid #d9d9d9;
}

.user-section__welcome {
  font-size: 26rpx;
  color: #666666;
}

/* 猫咪标语区域：左图 + 文案 */
.cat-slogan {
  width: 100%;
  margin-top: 0rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 0rpx;
  padding: 0rpx;
  border-radius: 40rpx;
}

.cat-slogan__image {
  left: 80rpx;
  width: 240rpx;
  height: 240rpx;
}

.cat-slogan-text {
  width: 500rpx;
  height: 200rpx;
}

/* 按钮区域整体布局 */
.btn-area {
  width: 100%;
  margin-top: 20rpx;
  display: flex;
  justify-content: center;
  gap: 56rpx;
}

.btn-area__item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

/* 拍照按钮外观 */
.btn-primary {
  height: 280rpx;
  left: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #FFFAE4;
  color: #ffffff;
  border-radius: 40rpx;
  border: 2rpx solid #623500 ;
}

/* 相册按钮外观 */
.btn-secondary {
  height: 280rpx;
  right: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #FFFAE4;
  color: #6e6e6e;
  border-radius: 40rpx;
  border: 2rpx solid #563300;
}

.btn-area__icon {
  width: 150rpx;
  height: 150rpx;
}

.btn-area__label {
  font-size: 40rpx;
  font-weight: 600;
  color: #563300;
  letter-spacing: 2rpx;
}



/* 结果卡片底部固定输入 */

/* 全屏 Loading 遮罩，AI 分析时使用 */
.loading-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.65);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 3000;
}

.loading-content {
  width: 320rpx;
  padding: 40rpx;
  border-radius: 30rpx;
  background: #ffffff;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 20rpx 40rpx rgba(0, 0, 0, 0.15);
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 6rpx solid #f1f1f1;
  border-top-color: #1296db;
  animation: spin 1s linear infinite;
}


@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 30rpx;
  font-size: 28rpx;
  color: #666;
}

/* ============================================================
   结果卡片浮层样式
   ============================================================ */
.result-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 2000;
  padding: 20rpx;
}

.result-card {
  width: 100%;
  height: 85vh;
  margin-bottom: 120rpx;    /*正好空出导航栏的高度*/
  background-color: #FFFAE4;
  border-radius: 30rpx;
  overflow: hidden;
  position: relative;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.3);
  display: flex;
  flex-direction: column;
}

.card-body {
  flex: 1;
  overflow: hidden;
}

.card-scroll {
  height: 100%;
  box-sizing: border-box;
  overflow-y: scroll;
  padding: 30rpx;
}


/* 分析辐射图 */
.analysis-ring {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 20rpx;
  padding: 20rpx 0 10rpx;
}

.ring-column {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/*维度*/
.ring-node {
  background: #FFECB7;
  border-radius: 30rpx;
  border: 2rpx solid #563300;
  padding: 18rpx 10rpx;
  text-align: center;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.05);
}

.node-label {
  font-size: 30rpx;
  font-weight: 600;
  color: #563300;
}

.node-value {
  display: block;
  margin-top: 10rpx;
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}
.ring-center {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.ring-photo {
  width: 320rpx;
  height: 320rpx;
  border-radius: 50%;
  border: 12rpx solid #ffd104;
  box-shadow: 0 18rpx 40rpx rgba(0, 0, 0, 0.08);
  overflow: hidden;
}

.ring-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/*昵称输入框*/
.cat-name-field {
  width: 80%;
  max-width: 360rpx;
  padding: 12rpx 24rpx;
  border-radius: 25rpx;
  /*渐变*/
  background: linear-gradient(to right, rgba(255, 189, 23, 0.8), rgba(255, 240, 200, 0.8));
  border: 2rpx solid #ededed;
  display: flex;
  align-items: center;
  gap: 12rpx;
  box-shadow: 0 10rpx 24rpx rgba(0, 0, 0, 0.06);
}

.name-icon {
  font-size: 26rpx;
}

.name-input {
  flex: 1;
  font-size: 30rpx;
  color: #563300;
}

.name-placeholder {
  color: #c1c1c1;
}

.name-input--locked {
  color: #999999;
}

/* 品种与情绪信息条 */
.info-ribbon {
  margin-top: 30rpx;
  padding: 20rpx;
  border-radius: 28rpx;
  background: #f9f9f9;
  display: flex;
  gap: 20rpx;
}

/*顶部品种+毛色*/
.info-ribbon {
  margin-top: 0rpx;
  padding: 20rpx;
  border-radius: 28rpx;
  background: #FFFAE4;
}

.ribbon-breedvalue {
  display: block;
  font-size: 36rpx;
  color: #563300;
  font-weight: 600;
}

.ribbon-patternvalue {
  display: block;
  margin-top: 10rpx;
  font-size: 28rpx;
  color: #563300;
  font-weight: 600;
}


/*情绪意图卡片*/
.emotion-strip {
  margin-top: 20rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: #fff6ec;
  border: 2rpx solid #ffd9b7;
  display: flex;
  flex-direction: column;
}

.strip-label {
  font-size: 24rpx;
  color: #aa7a3c;
}

.emotion-tags {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.emotion-pill {
  padding: 10rpx 24rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #fff;
}

.mood-pill {
  background-color: #ff9f68;
}

.intent-pill {
  background-color: #7d9dff;
}

/* 关闭按钮 */
.close-btn {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  width: 60rpx;
  height: 60rpx;
  background-color: rgba(0, 0, 0, 0.5);
  color: #fff;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 32rpx;
  z-index: 10;
}

/* 卡片图片区域 */
.card-image-box {
  width: 100%;
  height: 400rpx;
  overflow: hidden;
}

.card-image {
  width: 100%;
  height: 100%;
}

/*AI报告总结*/
.summary-section {
  margin-top: 24rpx;
  padding: 24rpx;
  border-radius: 28rpx;
  border: 2rpx solid #563300;
  background: linear-gradient(to top, rgba(255, 236, 183, 0.8) 0%, rgba(255, 236, 183, 0) 50%);
  box-shadow: 0 8rpx 26rpx rgba(116, 78, 21, 0.08);
}

/*初遇记录*/
.story-section {
  margin-left: 24rpx;
  margin-right: 24rpx;
  padding: 24rpx;
  border-radius: 28rpx;
  border: 2rpx solid #563300;
  background: #fff;
  box-shadow: 0 8rpx 26rpx rgba(116, 78, 21, 0.08);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 18rpx;
}

.section-title-box {
  min-width: 160rpx;
  padding: 0rpx 20rpx;
  border-radius: 16rpx;
  box-shadow: inset 0 -4rpx 0 rgba(255, 255, 255, 0.35);
}

.section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #563300;
}

.section-toggle {
  font-size: 26rpx;
  color: #ba7a1b;
}

.section-content {
  border-radius: 20rpx;
  padding: 0rpx;
}

.section-text,
.story-text {
  font-size: 28rpx;
  color: #563300;
  line-height: 1.7;
  word-break: break-word;
}

.story-section--footer {
  margin-top: 30rpx;
}

.story-input {
  margin-top: 0rpx;
  width: 100%;
  min-height: 100rpx;
  box-sizing: border-box;
  background: #fffdf7;
  font-size: 28rpx;
  color: #563300;
}

.story-input::placeholder {
  color: #c8a06b;
}

.story-actions {
  margin-top: 18rpx;
  display: flex;
  justify-content: flex-end;
  gap: 18rpx;
}

.story-action-btn {
  min-width: 180rpx;
  height: 60rpx;
  border-radius: 18rpx;
  border: 0.5rpx solid #563300;
  background: #FFD042;
  color: #563300;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 24rpx;
}

.story-action-btn--ghost {
  background: #FFD042;
  color: #563300;
}

.story-action-btn--ghost[disabled] {
  opacity: 0.6;
}

.story-action-btn--primary {
  background: #FFD7A8;
  color: #563300;
  border: 0.5rpx solid #563300;
}

.story-action-btn--primary[disabled] {
  opacity: 0.6;
}

/* 故事文案区域 */
.output-box {
  padding: 20rpx 30rpx;
  background-color: #f9f9f9;
  margin: 10rpx 30rpx;
  border-radius: 16rpx;
  border-left: 6rpx solid #1296db;
}

.output-text {
  font-size: 28rpx;
  color: #555;
  line-height: 1.6;
}



/* 发送期间的录音按钮显得不可用，提示用户等待 */
.voice-btn[disabled] {
  opacity: 0.4;
}

.send-btn {
  min-width: 150rpx;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  background: #d8d8d8;
  color: #666;
  border: none;
}

.send-btn--active {
  background: #1296db;
  color: #fff;
}

.send-btn[disabled] {
  opacity: 0.6;
}

.interaction-reply {
  background: #eef7ff;
  border-left: 6rpx solid #1296db;
  border-radius: 18rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.reply-label {
  font-size: 24rpx;
  color: #1296db;
  display: block;
  margin-bottom: 8rpx;
}

.reply-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
  word-break: break-word;
}

.card-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 24rpx;
}

.detail-action-btn {
  flex: 1;
  border: none;
  border-radius: 20rpx;
  padding: 0;
  background: transparent;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-btn__inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  width: 100%;
  height: 100%;
  padding: 24rpx 0;
}

.action-btn__icon {
  width: 80rpx;
  height: 80rpx;
}

.action-btn__label {
  font-size: 24rpx;
  font-weight: 600;
}

.catalog-btn {
  color: #563300;
}

.share-btn {
  color: #563300;
}

.catalog-btn[disabled] {
  opacity: 0.6;
}
