<view class="chat-page">
  <view class="chat-header">
    <view class="header-texts">
      <text class="title">咕噜博士</text>
      <text class="subtitle">解答关于猫咪的一切</text>
    </view>
    <view class="header-actions">
      <button class="history-btn" size="mini" bindtap="handleHistoryTap">历史</button>
      <button class="clear-btn" size="mini" bindtap="handleClearCache">清除缓存</button>
    </view>
  </view>

  <scroll-view
    class="message-list"
    scroll-y="true"
    scroll-with-animation="true"
    scroll-into-view="{{scrollIntoView}}"
  >
    <block wx:for="{{messages}}" wx:key="{{item.id}}">
      <block wx:if="{{item.status === 'failed'}}">
        <view id="{{item.id}}" class="retry-row">
          <text class="retry-text">助手忙碌，请稍后重试</text>
          <text class="retry-action" data-id="{{item.id}}" bindtap="retryMessage">点击重试</text>
        </view>
      </block>
      <block wx:else>
        <view id="{{item.id}}" class="message-row message-row--{{item.role}}">
          <image
            class="avatar-user"
            src="{{item.role === 'assistant' ? assistantAvatar : userAvatar}}"
            mode="aspectFill"
          ></image>
          <view class="bubble">
            <text class="bubble-text">{{item.content}}</text>
          </view>
        </view>
      </block>
    </block>

    <view class="message-row message-row--assistant" wx:if="{{isWaitingResponse}}">
      <image class="avatar-agent" src="{{assistantAvatar}}" mode="aspectFill"></image>
      <view class="bubble bubble--streaming">
        <text class="bubble-text" wx:if="{{streamingMessage}}">{{streamingMessage}}</text>
        <view class="typing-dots" wx:if="{{!streamingMessage}}">
          <text>.</text>
          <text>.</text>
          <text>.</text>
        </view>
      </view>
    </view>
    <view id="streaming-anchor"></view>
  </scroll-view>

<!-- 输入框 -->
  <view class="input-bar" style="bottom: {{keyboardHeight > 0 ? keyboardHeight + 'px' : '32rpx'}};">
    <view class="input-main">
      <textarea
        class="input-area"
        placeholder="向咕噜博士提问"
        value="{{inputValue}}"
        bindinput="handleInput"
        bindfocus="handleInputFocus"
        bindblur="handleInputBlur"
        auto-height="true"
        adjust-position="false"
        maxlength="500"
        show-confirm-bar="false"
       ></textarea>
      <button
        class="send-icon-btn"
        bindtap="sendMessage"
        disabled="{{isSending || !canSend}}"
       style="width: 93rpx; display: flex; box-sizing: border-box; left: 0rpx; top: 0rpx">
        <image class="send-icon" src="https://meetmeow.oss-cn-wuhan-lr.aliyuncs.com/source/send.png" style="opacity: {{isSending ? 0.60 : 1}};" mode="aspectFit"></image>
      </button>
    </view>
  </view>
</view>
