.alerts-page {
  min-height: 100vh;
  padding: 32rpx;
  background: #FFFAE4;
  box-sizing: border-box;
}

.hero {
  margin-bottom: 24rpx;
}

.hero-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #563300;
}

.hero-sub {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #7a5633;
}

.alerts-list {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx 20rpx;
  box-shadow: 0 10rpx 24rpx rgba(0, 0, 0, 0.08);
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  column-gap: 12rpx;
}

.title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
  min-width: 0;
}

.alert-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #ff5d5d;
}

.alert-title {
  font-size: 28rpx;
  color: #563300;
  font-weight: 600;
}

.alert-desc {
  font-size: 24rpx;
  color: #563300;
}

.ghost {
  background: #ffe18f;
  color: #563300;
  width: 0px;
  border: none;
  border-radius: 999rpx;
  padding: 6rpx 20rpx;
  font-size: 20rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.primary {
  margin-top: 32rpx;
  background: linear-gradient(135deg, #ffd042, #ffd042);
  color: #563300;
  border: none;
  border-radius: 14rpx;
  padding: 16rpx 0;
  font-size: 28rpx;
  font-weight: 600;
}

.remind{
  display: flex;
  flex-direction: column;
  margin-top: 60rpx;
  text-align: center;
  justify-content: center; /* 整体水平居中 */
}

.remind-text{
  font-size: 26rpx;
  color: #563300;
}