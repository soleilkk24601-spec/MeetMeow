.share-page {
	min-height: 100vh;
	padding: 32rpx;
  background: #FFD7A8;
	box-sizing: border-box;
}


.empty-state {
	margin-top: 200rpx;
	display: flex;
	flex-direction: column;
	align-items: center;
	color: #999;
}

.empty-icon {
	font-size: 72rpx;
	margin-bottom: 12rpx;
}

.empty-text {
	font-size: 30rpx;
	margin-bottom: 6rpx;
}

.empty-hint {
	font-size: 26rpx;
}

.post-card {
	background: #FFFAE4;
	border-radius: 28rpx;
	padding: 24rpx;
	margin-bottom: 24rpx;
	box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.06);
}

.post-header {
	display: flex;
	align-items: center;
	gap: 16rpx;
}

.avatar {
	width: 72rpx;
	height: 72rpx;
	border-radius: 50%;
	background: #eee;
}

.author-info {
	flex: 1;
	display: flex;
	flex-direction: column;
}

.author-name {
	font-size: 30rpx;
	color: #563300;
	font-weight: 600;
}

.post-time {
	font-size: 24rpx;
	color: #563300
}


.post-content {
	margin: 20rpx 0 12rpx;
}

.content-text {
	font-size: 28rpx;
	color: #563300;
  line-height: 1.6;
  font-weight:400rpx;
}

.post-media {
	width: 100%;
	border-radius: 20rpx;
	height: 320rpx;
	background: #f2f2f2;
  object-fit: cover;
  border: 4rpx solid #563300;
}

.lbs-row {
	display: flex;
	align-items:center;
	justify-content: space-between;
}
  
.lbs-text {
	font-size: 26rpx;
	color: #7a5c2f;
}

.lbs-btn {
	border: none;
	border-radius: 999rpx;
	padding: 8rpx 20rpx;
	font-size: 24rpx;
	background: #ffe0ba;
	color: #a35300;
}

.post-actions {
	margin-top: 20rpx;
	display: flex;
	justify-content: flex-end;
	gap: 16rpx;
}

.like-btn,
.delete-btn {
	border: none;
	border-radius: 999rpx;
	padding: 10rpx 24rpx;
	font-size: 26rpx;
}

.like-btn {
	background: #FFD042;
	color: #563300;
}

.delete-btn {
	background: #ffecef;
	color: #ff4d4f;
}

.loading-row,
.end-row {
	text-align: center;
	color: #aaa;
	padding: 20rpx 0 60rpx;
	font-size: 26rpx;
}
