.editor-page {
  padding: 32rpx;
  background: #FFFAE4;
  min-height: 100vh;
  box-sizing: border-box;
}

.preview-card,
.editor-block {
  background: #FFf;
  border: 4rpx solid #563300;
  border-radius: 28rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 12rpx 28rpx rgba(0, 0, 0, 0.06);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #563300;
}

.preview-image {
  width: 100%;
  height: 320rpx;
  border-radius: 24rpx;
  margin-top: 16rpx;
  object-fit: cover;
  background: #f0f0f0;
}

.preview-placeholder {
  display: block;
  margin-top: 16rpx;
  font-size: 28rpx;
  color: #999;
}

.preview-location {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #563300;
}

.editor-textarea {
  margin-top: 16rpx;
  width: 100%;
  min-height: 200rpx;
  border-radius: 20rpx;
  padding: 16rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  background: #f6f7fb;
}

.action-row{
  margin-top: 10rpx;
  display: flex;
  flex-direction: row;
}

.action-button{
  border-radius: 10%;
  background-color: #FFD042;
  color: #563300;
  font-size-adjust: 10rpx;
}

.switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 12rpx;
}

.switch-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #563300;
}

.switch-hint {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #563300;
}

.submit-btn {
  width: 100%;
  border: none;
  border-radius: 999rpx;
  padding: 20rpx 0;
  font-size: 30rpx;
  background: #FFD042;
  color: #563300;
}
