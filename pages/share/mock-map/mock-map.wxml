<view class="mock-map-page">
  <view class="card">
    <view class="header">
      <image class="paw-icon" src="{{assets.paw}}" mode="widthFix" />
      <text class="header-title">{{title}}</text>
    </view>
    
    <view class="map-block">
      <map
        class="map-image"
        longitude="{{lng}}"
        latitude="{{lat}}"
        scale="16"
        markers="{{markers}}"
        show-location
      >
        <cover-image class="marker" src="{{assets.marker}}" mode="widthFix" />
      </map>
    </view>

    <view class="address-row">
      <image class="addr-icon" src="{{assets.location}}" mode="widthFix" />
      <text class="address-text">{{address}}</text>
    </view>

    <view class="meta-row">
      <view class="meta-item">
        <text class="meta-label">距离</text>
        <text class="meta-value">{{distance}}</text>
      </view>
      <view class="meta-divider"></view>
      <view class="meta-item">
        <image class="car-icon" src="{{assets.car}}" mode="widthFix" />
        <text class="meta-value">{{duration}}</text>
      </view>
    </view>

    <button class="nav-btn" bindtap="mockNavigate">
      <image class="nav-icon" src="{{assets.nav}}" mode="widthFix" />
      <text class="nav-text">导航到这里</text>
    </button>
  </view>
</view>
