.map-page {
  min-height: 100vh;
  display: flex;
  justify-content: center;
  align-items: center;
  background: linear-gradient(135deg, #0f172a, #1e293b 60%, #0b1526);
  color: #e2e8f0;
  padding: 32px 16px;
  box-sizing: border-box;
}

.map-card {
  width: 100%;
  max-width: 720rpx;
  background: rgba(15, 23, 42, 0.8);
  border: 1px solid rgba(148, 163, 184, 0.2);
  border-radius: 24rpx;
  box-shadow: 0 12px 40px rgba(0, 0, 0, 0.35);
  padding: 28rpx;
  box-sizing: border-box;
}

.map-header {
  margin-bottom: 20rpx;
}

.title {
  font-size: 32rpx;
  font-weight: 700;
  color: #f8fafc;
}

.subtitle {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #94a3b8;
}

.map-viewport {
  position: relative;
  height: 360rpx;
  margin: 12rpx 0 20rpx;
  border-radius: 20rpx;
  overflow: hidden;
  background: linear-gradient(180deg, #1e3a8a 0%, #0ea5e9 55%, #10b981 100%);
  border: 1px solid rgba(148, 163, 184, 0.2);
  box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.04);
}

.sky {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 55%;
  background: radial-gradient(circle at 30% 20%, rgba(236, 254, 255, 0.35), transparent 45%),
              radial-gradient(circle at 70% 10%, rgba(244, 255, 255, 0.25), transparent 40%),
              linear-gradient(180deg, #1d4ed8 0%, #38bdf8 100%);
}

.ground {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 45%;
  background: radial-gradient(circle at 40% 0%, rgba(16, 185, 129, 0.5), transparent 45%),
              linear-gradient(180deg, #0ea5e9 0%, #14b8a6 60%, #0f766e 100%);
}

.pin {
  position: absolute;
  left: 50%;
  top: 45%;
  transform: translate(-50%, -50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  animation: float 2.5s ease-in-out infinite;
}

.pin-head {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #fbbf24, #f97316);
  box-shadow: 0 6rpx 20rpx rgba(249, 115, 22, 0.5);
}

.pin-body {
  width: 14rpx;
  height: 32rpx;
  border-radius: 10rpx;
  background: linear-gradient(180deg, #ea580c, #c2410c);
  box-shadow: 0 6rpx 12rpx rgba(234, 88, 12, 0.45);
}

.glow {
  position: absolute;
  left: 50%;
  bottom: 18%;
  width: 160rpx;
  height: 60rpx;
  transform: translateX(-50%);
  background: radial-gradient(circle, rgba(56, 189, 248, 0.35) 0%, rgba(56, 189, 248, 0) 60%);
  filter: blur(2rpx);
  animation: pulse 3s ease-in-out infinite;
}

.info {
  margin: 12rpx 0 18rpx;
}

.info-line {
  display: block;
  font-size: 24rpx;
  color: #cbd5e1;
  line-height: 1.6;
}

.nav-btn {
  width: 100%;
  background: linear-gradient(135deg, #0ea5e9, #2563eb);
  color: #f8fafc;
  border: none;
  border-radius: 16rpx;
  padding: 18rpx 0;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 10rpx 25rpx rgba(37, 99, 235, 0.35);
}

@keyframes float {
  0% { transform: translate(-50%, -48%); }
  50% { transform: translate(-50%, -54%); }
  100% { transform: translate(-50%, -48%); }
}

@keyframes pulse {
  0% { opacity: 0.6; transform: translateX(-50%) scale(0.96); }
  50% { opacity: 1; transform: translateX(-50%) scale(1.05); }
  100% { opacity: 0.6; transform: translateX(-50%) scale(0.96); }
}
