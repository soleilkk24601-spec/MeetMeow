.mock-map-page {
  min-height: 100vh;
  background: #ABABAB;
  padding: 48rpx 28rpx 120rpx;
  box-sizing: border-box;
  display: flex;
  justify-content: center;
}

.card {
  width: 100%;
  background: #FFFAE4;
  border-radius: 26rpx;
  box-shadow: 0 18rpx 50rpx rgba(0, 0, 0, 0.18);
  padding: 30rpx;
  box-sizing: border-box;
}

.header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 30rpx;
  margin-bottom: 20rpx;
}
.header-subtitle {
  display: block;
  margin-left: 10rpx;
  margin-bottom: 10rpx;
  font-size: 24rpx;
  color: #563300;
}

.paw-icon {
  width: 50rpx;
  height: 50rpx;
}

.header-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #563300;
}

.map-block {
  position: relative;
  border: 6rpx solid #563300;
  border-radius: 22rpx;
  overflow: hidden;
  margin-bottom: 28rpx;
}

.map-image {
  width: 100%;
  height: 460rpx;
  display: block;
  background: #d3d8df;
}

.marker {
  position: absolute;
  width: 56rpx;
  height: 76rpx;
  left: 50%;
  bottom: 30%;
  transform: translateX(-50%);
}

.address-row {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  color: #563300;
  font-size: 28rpx;
  line-height: 1.6;
  margin-bottom: 18rpx;
}

.addr-icon {
  width: 28rpx;
  height: 32rpx;
  margin-top: 4rpx;
}

.address-text {
  flex: 1;
}

.meta-row {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  gap: 18rpx;
  margin-bottom: 26rpx;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
  color: #563300;
}

.meta-label {
  font-size: 26rpx;
  color: #6a4a1c;
}

.meta-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #563300;
}

.car-icon {
  width: 32rpx;
  height: 24rpx;
}

.meta-divider {
  width: 2rpx;
  height: 34rpx;
  background: #c8b48d;
}

.nav-btn {
  width: 100%;
  height: 72rpx;
  margin-top: 12rpx;
  background: #FFD042;
  color: #563300;
  border: none;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  font-size: 30rpx;
  font-weight: 700;
  box-shadow: 0 14rpx 24rpx rgba(0, 0, 0, 0.12);
}

.nav-btn:active {
  opacity: 0.85;
}

.nav-icon {
  width: 32rpx;
  height: 32rpx;
}

.nav-text {
  color: #563300;
}
