.floating-root {
  position: fixed;
  right: 32rpx;
  top: 80%;
  transform: translateY(-50%);
  z-index: 999;
}

.ball {
  width: 100rpx;
  height: 100rpx;
  border-radius: 60rpx;
  background: linear-gradient(135deg, #f7d86a, #f7b733);display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.2);

}

.ball-icon {
  width: 96rpx;
  height: 96rpx;
}

.ball-text {
  letter-spacing: 2rpx;
}
